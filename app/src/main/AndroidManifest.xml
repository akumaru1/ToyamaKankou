<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.TravelApp"
        tools:targetApi="31">
        <!-- New Unified Activities -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />
        <activity
            android:name=".ChooseActivity"
            android:exported="false" />
        <activity
            android:name=".ListActivity"
            android:exported="false" />
        <activity
            android:name=".MannerActivity"
            android:exported="false" />
        <activity
            android:name=".FoodmanaActivity"
            android:exported="false" />
        <activity
            android:name=".OnsenActivity"
            android:exported="false" />
        <activity
            android:name=".DenshaActivity"
            android:exported="false" />
        
        <!-- Existing Activities (Keep) -->
        <activity
            android:name=".DetailActivity"
            android:exported="false" />
        <activity
            android:name=".Shokuji"
            android:exported="false" />
        <activity
            android:name=".Kankouchi"
            android:exported="false" />
        <activity
            android:name=".Language"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>